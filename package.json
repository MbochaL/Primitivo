{
  "name": "primitivo",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de fidelización y beneficios de Primitivo (pan · café · cocina)",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "gen:spec": "turbo run gen:spec",
    "generate:client": "turbo run generate:client",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3"
  }
}
