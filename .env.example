# ─────────────────────────────────────────────────────────────
# Primitivo — variables de entorno (copiar a .env y completar)
# ─────────────────────────────────────────────────────────────

# ── Backend (apps/api) ──────────────────────────────────────
# Conexión a PostgreSQL (pgx / sqlc / golang-migrate)
# Local:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/primitivo?sslmode=disable
# Producción (Neon): usar la connection string DIRECTA (sin "-pooler") para que las
# migraciones de golang-migrate puedan tomar advisory locks. Requiere sslmode=require, ej:
#   postgresql://USER:PASS@ep-xxxx.sa-east-1.aws.neon.tech/primitivo?sslmode=require

# Puerto HTTP del servidor Gin
API_PORT=8080

# Entorno: development | production
APP_ENV=development

# Secreto para firmar los JWT (cambiar por un valor largo y aleatorio)
JWT_SECRET=cambiame-por-un-secreto-largo-y-aleatorio
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Orígenes permitidos por CORS (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# ── Frontend (apps/web) ─────────────────────────────────────
# URL base de la API que consume el cliente generado
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
